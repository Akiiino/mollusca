define-command -hidden git-status-goto-source %{
    evaluate-commands -draft -save-regs c %{
        execute-keys 'x'
        set-register c %sh{
            path=$(printf '%s' "$kak_selection" | sed -n '
                /^\t/ {
                    s/^\t//
                    s/^\(both \)\?\(added\|copied\|deleted\|modified\|renamed\|typechange\|unmerged\|new file\)\( by us\| by them\)\?: *//
                    s/.* -> //
                    p
                    b
                }
                /^[ ACDMRTU?!][ ACDMRTU?!] / {
                    s/^...//
                    s/.* -> //
                    p
                }')
            [ -n "$path" ] || exit 0
            case "$path" in
                /*) printf '%s' "$path" ;;
                *)  printf '%s/%s' "${PWD}" "$path" ;;
            esac
        }
        evaluate-commands %sh{
            [ -n "$kak_reg_c" ] || echo "fail 'git-status: no file on this line'"
        }
        evaluate-commands -client %val{client} %{
            evaluate-commands -try-client %opt{jumpclient} %{
                edit -existing -- %reg{c}
            }
        }
    }
}

hook -group git-status-goto-source global WinSetOption filetype=git-status %{
    map buffer normal <ret> ':git-status-goto-source<ret>' -docstring 'Jump to file under cursor'
    hook -once -always window WinSetOption filetype=.* %{
        unmap buffer normal <ret> ':git-status-goto-source<ret>'
    }
}

