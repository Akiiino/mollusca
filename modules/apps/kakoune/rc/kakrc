define-command fuzzy-edit -docstring "find file and edit" -params 1 %{ edit %arg{1} }
complete-command fuzzy-edit shell-script-candidates %{
    rg --files | awk -F/ '{
        k = ""
        for (i = 1; i < NF; i++) k = k "1" $i "\001"
        print k "0" $NF "\t" $0
    }' | sort | cut -f2-
}

define-command cwd-edit -params 1 \
    -docstring "edit a file in the current buffer's directory (no cd)" %{
    edit %sh{
        dir=$(dirname "$kak_bufname")
        if [ "$dir" = "." ]; then printf %s "$1"; else printf %s "$dir/$1"; fi
    }
}
complete-command cwd-edit shell-script-candidates %{
    cd "$(dirname "$kak_buffile")" && rg --files | awk -F/ '{
        k = ""
        for (i = 1; i < NF; i++) k = k "1" $i "\001"
        print k "0" $NF "\t" $0
    }' | sort | cut -f2-
}

map global user e ': fuzzy-edit ' -docstring 'edit with fuzzy matching'
map global user E ': cwd-edit ' -docstring 'edit next to current buffer'
