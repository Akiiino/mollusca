+/// Compute the list of `Change`s representing the edit from `prev_text`
+/// to `text`.
+///
+/// When the two texts have the same line count, emits one `Change` per
+/// differing line, each carrying its own tight (prefix-and-suffix-
+/// trimmed) old/new content. This is what multi-cursor edits need:
+/// without it, a multi-region edit collapses into a single `Change`
+/// whose lookup position only ever lands at the *last* edit site, so
+/// `handle_change_delta` only fires there and only the last form sees
+/// its `indent_delta` propagate.
+///
+/// When line counts differ (e.g. a newline was added or removed),
+/// falls back to a single `Change` spanning first-diff..last-diff.
+pub fn compute_text_changes<'a>(prev_text: &'a str, text: &'a str) -> Vec<Change> {
+    if prev_text == text {
+        return vec![];
+    }
+
+    let prev_lines: Vec<&str> = prev_text.split('\n').map(chomp_cr).collect();
+    let new_lines: Vec<&str> = text.split('\n').map(chomp_cr).collect();
+
+    if prev_lines.len() != new_lines.len() {
+        return whole_text_diff(prev_text, text);
+    }
+
+    prev_lines
+        .iter()
+        .zip(new_lines.iter())
+        .enumerate()
+        .filter_map(|(i, (p, n))| line_diff(p, n, i))
+        .collect()
+}
