+        } else if range.start.character == 0
+            && range.end.character == 0
+            && range.end.line > range.start.line
+            && (range.end.line as usize) <= text.len_lines()
+        {
+            // A single line-aligned edit that replaces a multi-line region but does not start at
+            // the beginning of the buffer (e.g. ruff coalesces all its formatting changes into one
+            // edit from the first changed line to EOF). Applied as-is this is one big replacement,
+            // collapsing the cursor to the edit's end. Split it into a minimal line-based edit
+            // sequence so untouched lines keep the cursor in place.
+            let start_line = range.start.line as usize;
+            let end_line = range.end.line as usize;
+            let start_byte = text.line_to_byte(start_line);
+            let end_byte = text.line_to_byte(end_line);
+            let mut old_sub = String::new();
+            for chunk in text.byte_slice(start_byte..end_byte).chunks() {
+                old_sub.push_str(chunk);
+            }
+            let new_text = &text_edits[0].as_ref().new_text;
+            let new_text = if new_text.ends_with('\n') || !old_sub.ends_with('\n') {
+                Cow::Borrowed(new_text)
+            } else {
+                Cow::Owned(new_text.to_string() + "\n")
+            };
+            let sub_edits = minimal_edit_sequence::<TextEdit>(
+                &Rope::from_str(&old_sub),
+                &Rope::from_str(&new_text),
+            );
+            text_edits = sub_edits
+                .into_iter()
+                .map(|mut te| {
+                    te.range.start.line += start_line as u32;
+                    te.range.end.line += start_line as u32;
+                    T::from_text_edit(te)
+                })
+                .collect();
+            debug!(
+                to_editor,
+                "Computed edit script to split up multi-line text edit"
+            );
+            for te in &text_edits {
+                debug!(to_editor, "{:?}", te.as_ref());
+            }
         }
     }

