+    #[test]
+    pub fn lsp_text_edits_to_kakoune_split_partial_buffer_edit() {
+        // Mirrors ruff's formatting output: a single edit that spans from the first changed line
+        // to EOF, not starting at the beginning of the buffer. It should be split so untouched
+        // lines do not move the cursor.
+        let buffer = Rope::from_str(indoc!(
+            r#"line0
+               line1
+               line2 needs reformatting
+               line3
+               line4
+             "#
+        ));
+        let text_edits = vec![edit(
+            2,
+            0,
+            5,
+            0,
+            "line2 reformatted\nline3\nline4\n",
+        )];
+        let result = lsp_text_edits_to_kakoune(
+            &mock_to_editor(),
+            &Some(ClientId("test_client".to_string())),
+            text_edits,
+            &buffer,
+            OffsetEncoding::Utf8,
+        );
+        let expected = indoc!(
+            r#"select 3.1,3.1000000
+               execute-keys "cline2 reformatted
+               <esc>""#
+        )
+        .to_string();
+        assert_eq!(result, Some(expected));
+    }
